{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_EXPORTER_OTLP_HEADERS": ""
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(gh:*)",
      "Bash(npm run:*)",
      "Bash(oxlint:*)",
      "Bash(oxfmt:*)",
      "Bash(git:*)",
      "Bash(curl:*)",
      "Bash(rtk:*)",
      "WebSearch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Write\" && (tool_input.file_path matches \"\\.(md|txt)$\")",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-doc-files.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-build-dirs.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+push\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-force-push.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+commit\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-conventional-commit.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"Reminder (no need to respond): Run the project formatter, typechecker, linter. Also check: functions < 30 lines, functions have docstrings, file < 800 lines, no hardcoded values (use existing types/const).\"}}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": []
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/AI/settings/claude/statusline.sh"
  },
  "enabledPlugins": {
    "dodo@artificial-jellybeans": true
  },
  "extraKnownMarketplaces": {
    "artificial-jellybeans": {
      "source": {
        "source": "github",
        "repo": "thesimonho/artificial-jellybeans"
      }
    }
  },
  "outputStyle": "explanatory",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": ["*.github.com", "*.githubusercontent.com", "*.anthropic.com"],
      "allowUnixSockets": ["$SSH_AUTH_SOCK", "/run/user/1000/agent-browser", "~/.gnupg/S.gpg-agent"]
    },
    "filesystem": {
      "allowWrite": ["/tmp", "~/.gnupg"]
    },
    "excludedCommands": ["docker:*", "git:*"]
  },
  "effortLevel": "medium",
  "advisorModel": "opus",
  "skipDangerousModePermissionPrompt": true,
  "preferredNotifChannel": "auto",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": false,
  "useAutoModeDuringPlan": true,
  "voiceEnabled": true,
  "disableBypassPermissionsMode": false
}
