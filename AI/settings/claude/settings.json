{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(npm run *)",
      "WebSearch",
      "WebFetch",
      "mcp__plugin_context7_context7__query-docs"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Write\" && (tool_input.file_path matches \"\\.(md|txt)$\")",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-doc-files.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-build-dirs.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+push\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-force-push.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+commit\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-conventional-commit.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '⚠️ Doublecheck: did you run linter/formatter/type check? Did you keep functions small? Is the file shorter than 800 lines? Were any tests needed?' >&2"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ~/.claude/statusline/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "artificial-jellybeans": {
      "source": {
        "source": "github",
        "repo": "thesimonho/artificial-jellybeans"
      }
    }
  },
  "outputStyle": "explanatory",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "auth.docker.io",
        "*.npmjs.org",
        "github.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.golang.org",
        "api.anthropic.com",
        "sentry.io",
        "*.sentry.io",
        "o*.ingest.sentry.io",
        "*.playwright.dev",
        "playwright.azureedge.net",
        "registry.shadcn.com",
        "*.context7.com"
      ],
      "allowUnixSockets": [
        "$SSH_AUTH_SOCK",
        "/run/user/1000/agent-browser"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "//tmp",
        "~/.cache/go-build/"
      ]
    },
    "excludedCommands": [
      "git",
      "docker"
    ]
  },
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
