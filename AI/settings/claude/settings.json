{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "500000",
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_ENABLE_PROMPT_SUGGESTION": "false",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA": "1",
    "OTEL_TRACES_EXPORTER": "otlp",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
    "OTEL_EXPORTER_OTLP_HEADERS": ""
  },
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(ls *)",
      "Bash(gh *)",
      "Bash(npm run *)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(just *)",
      "Bash(rtk *)",
      "mcp__context7__query-docs",
      "mcp__context7__resolve-library-id"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js block-doc-files"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js block-build-dirs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js block-plan-references"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js block-force-push"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js check-conventional-commit"
          },
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js verify-gate"
          },
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js scan-secrets"
          },
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js simplify-nudge"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js rtk-nudge"
          },
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js justfile-nudge"
          }
        ]
      },
      {
        "matcher": "Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js lsp-nudge"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js branch-guard"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js block-debug-logging"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js commit-format-nudge"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js check-plan-filename"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js memory-redirect"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js surface-file-header"
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js coupling-surface"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js verify-track"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js lint-config-files"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js delete-branch-nudge"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js check-file-size"
          },
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js no-hard-linebreaks"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js compaction-nudge"
          }
        ]
      },
      {
        "matcher": "TaskCreate",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/dotfiles/AI/lib/hooks/runners/claude.js task-delegation-nudge"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": []
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/AI/settings/claude/statusline.sh"
  },
  "enabledPlugins": {
    "dodo@artificial-jellybeans": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "artificial-jellybeans": {
      "source": {
        "source": "github",
        "repo": "thesimonho/artificial-jellybeans"
      }
    }
  },
  "outputStyle": "default",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com"
      ],
      "allowUnixSockets": [
        "$SSH_AUTH_SOCK",
        "/run/user/1000/agent-browser",
        "~/.gnupg/S.gpg-agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/.gnupg"
      ]
    },
    "excludedCommands": [
      "docker:*",
      "git:*"
    ]
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "preferredNotifChannel": "auto",
  "teammateMode": "auto",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "disableBypassPermissionsMode": false
}
