{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(npm:run *)",
      "Bash(gh:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == \"Write\" && (tool_input.file_path matches \"\\.(md|txt)$\")",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-doc-files.js"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-build-dirs.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+push\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/block-force-push.js"
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"git\\s+commit\"",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-conventional-commit.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"You just edited a file. Run the project formatter and linter on it now. Also check: functions < 30 lines, functions have docstrings, file < 800 lines, no hardcoded values (use existing types/const).\"}}'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": []
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": []
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": []
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/dotfiles/AI/settings/claude/statusline.sh"
  },
  "enabledPlugins": {
    "dodo@artificial-jellybeans": true
  },
  "extraKnownMarketplaces": {
    "artificial-jellybeans": {
      "source": {
        "source": "github",
        "repo": "thesimonho/artificial-jellybeans"
      }
    }
  },
  "outputStyle": "explanatory",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.githubusercontent.com",
        "*.anthropic.com"
      ],
      "allowUnixSockets": [
        "$SSH_AUTH_SOCK",
        "/run/user/1000/agent-browser",
        "~/.gnupg/S.gpg-agent"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "~/.gnupg"
      ]
    },
    "excludedCommands": [
      "docker:*"
    ]
  },
  "advisorModel": "opus",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
