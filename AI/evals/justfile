set shell := ["zsh", "-cu"]
set positional-arguments := true
set tempdir := "/tmp"
set working-directory := "../.."

eval_python := "AI/evals/.venv/bin/python"
mlflow_compose := "infra/compose/mlflow.yml"

default:
    @just --justfile AI/evals/justfile --list

# Install the isolated eval harness and HomeOps fixture dependencies.
eval-setup: eval-homeops-setup
    python3 -m venv AI/evals/.venv
    AI/evals/.venv/bin/pip install "mlflow[genai]==3.14.0"

# Install the locked single-package HomeOps web application dependencies.
eval-homeops-setup:
    npm ci --prefix AI/evals/environments/homeops/project

# Start MLflow, bind Alloy to the eval experiment, and wait for both services.
eval-up: eval-up-mlflow eval-wait-mlflow eval-bootstrap-alloy eval-up-alloy eval-wait-alloy

# Start the MLflow service.
eval-up-mlflow:
    docker compose -f {{ mlflow_compose }} up -d mlflow

# Wait up to 60 seconds for MLflow to answer.
eval-wait-mlflow:
    #!/usr/bin/env zsh
    for attempt in {1..60}; do
      if curl --fail --silent --output /dev/null http://127.0.0.1:5000; then
        exit 0
      fi
      sleep 1
    done
    print -u2 "Timed out waiting for http://127.0.0.1:5000"
    exit 1

# Create the experiment and write Alloy's ignored runtime environment file.
eval-bootstrap-alloy:
    #!/usr/bin/env zsh
    if [[ ! -x "{{ eval_python }}" ]]; then
      print -u2 "Missing {{ eval_python }}; run 'just eval-setup' first"
      exit 1
    fi
    {{ eval_python }} AI/evals/lib/mlflow_experiment_bootstrap.py

# Start Alloy after its MLflow experiment ID is available.
eval-up-alloy:
    docker compose -f {{ mlflow_compose }} up -d alloy

# Wait up to 60 seconds for Alloy to report ready.
eval-wait-alloy:
    #!/usr/bin/env zsh
    for attempt in {1..60}; do
      if curl --fail --silent --output /dev/null http://127.0.0.1:12345/-/ready; then
        exit 0
      fi
      sleep 1
    done
    print -u2 "Timed out waiting for http://127.0.0.1:12345/-/ready"
    exit 1

# Run the eval suite in MLflow. Pass runner flags directly to the recipe.
eval-mlflow *args:
    {{ eval_python }} AI/evals/run_mlflow_eval.py "$@"

# Compare full instructions with one component removed from the control arm.
eval-compare agent component case_id:
    {{ eval_python }} AI/evals/run_mlflow_eval.py --agent "{{ agent }}" --case-id "{{ case_id }}" --compare-component "{{ component }}"

# Preview component coverage and CLI usage without invoking an agent or MLflow.
eval-plan agent component repetitions="1":
    {{ eval_python }} AI/evals/plan_evaluation_campaign.py --agent "{{ agent }}" --component "{{ component }}" --repetitions "{{ repetitions }}"

# Run the suite with the selected agent CLI.
eval-run agent:
    just --justfile AI/evals/justfile eval-mlflow --agent "{{ agent }}"

# Show local service state.
eval-status:
    docker compose -f {{ mlflow_compose }} ps

# Follow MLflow and Alloy logs.
eval-logs:
    docker compose -f {{ mlflow_compose }} logs --follow --tail=100

# Stop MLflow without deleting its data.
eval-down:
    docker compose -f {{ mlflow_compose }} down

# Run behavior tests for the harness contracts.
eval-test:
    {{ eval_python }} -m unittest discover -s AI/evals/tests -v

# Run local harness and Compose validation.
eval-verify:
    {{ eval_python }} -m unittest discover -s AI/evals/tests -v
    {{ eval_python }} -m compileall -q AI/evals
    npm run build --prefix AI/evals/environments/homeops/project
    npm test --prefix AI/evals/environments/homeops/project
    docker compose -f {{ mlflow_compose }} config --quiet
    docker run --rm -e MLFLOW_EXPERIMENT_ID=1 -v "$PWD/infra/compose/alloy.config:/etc/alloy/config.alloy:ro" grafana/alloy:v1.18.0 validate /etc/alloy/config.alloy
