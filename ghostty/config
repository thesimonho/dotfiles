config-file = keybindings
custom-shader = shaders/cursor_warp.glsl
custom-shader = shaders/ripple_rectangle_cursor.glsl

font-family = CaskaydiaCove Nerd Font
font-style = SemiLight
font-size = 12
font-feature = -calt, -clig, -liga, -dlig

adjust-underline-position = 2

theme = light:kanagawa-paper-canvas,dark:kanagawa-paper-ink

mouse-shift-capture = true
mouse-hide-while-typing = true
focus-follows-mouse = true

unfocused-split-opacity = 0.5
background-opacity = 0.97
background-blur = true
bold-color = bright
bold-is-bright = true

link-url = true
link-previews = true

initial-window = false
tab-inherit-working-directory = true
split-inherit-working-directory = true
window-theme = system
window-subtitle = working-directory
window-save-state = always
window-new-tab-position = end
window-theme = system
window-padding-x = 0
window-padding-y = 0
window-padding-balance = true
window-inherit-working-directory = false
window-show-tab-bar = auto

clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
copy-on-select = false
cursor-click-to-move = true
right-click-action = context-menu
mouse-reporting = true

quit-after-last-window-closed = false

quick-terminal-position = top

linux-cgroup = always
linux-cgroup-hard-fail = false

macos-option-as-alt = true
shell-integration-features = true

notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
