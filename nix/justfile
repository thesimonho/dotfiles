FLAKE_DIR := "."

# Inputs excluded from `just update` (heavy rebuilds). Bump explicitly.

PINNED := "nixpkgs-pinned"
[private]
_nix := "nix --extra-experimental-features 'nix-command flakes'"

# Update flake inputs (skips PINNED), or a subset: `just update llm-agents nixpkgs`
update *inputs:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{ inputs }}" ]; then
      {{ _nix }} flake update {{ inputs }}
    else
      all=$({{ _nix }} eval --raw --impure --expr \
        'builtins.concatStringsSep "\n" (builtins.attrNames (builtins.getFlake (toString ./.)).inputs)')
      to_update=$(comm -23 <(echo "$all" | sort) <(echo "{{ PINNED }}" | tr ' ' '\n' | sort))
      echo "==> Updating: $(echo $to_update | tr '\n' ' ')"
      {{ _nix }} flake update $to_update
    fi

# Bump pinned inputs to latest (e.g. nixpkgs-pinned tracks unstable HEAD)
update-pinned:
    {{ _nix }} flake update {{ PINNED }}

# Show flake outputs (homeConfigurations, apps, etc.)
show:
    {{ _nix }} flake show {{ FLAKE_DIR }}

# Regenerate generated repo docs
[private]
docs:
    ./scripts/write-skills-readme.sh

# Describe dotfiles inventory: `just describe hosts`, `just describe desktop`, `just describe skills`
describe target="hosts" detail="":
    #!/usr/bin/env bash
    set -euo pipefail
    target="{{ target }}"

    case "$target" in
      hosts)
        {{ _nix }} eval --json {{ FLAKE_DIR }}#homeConfigurations --apply 'configs: builtins.attrNames configs' | jq -r '.[]'
        ;;
      completions)
        echo "carapace: $(command -v carapace || true)"
        echo "bridges: ${CARAPACE_BRIDGES:-unset}"
        echo "specs: ${XDG_CONFIG_HOME:-$HOME/.config}/carapace/specs"
        zsh -ic 'for cmd in git just nix gh docker systemctl ssh; do print -r -- "$cmd -> ${_comps[$cmd]-unset}"; done' 2>/dev/null
        ;;
      skills)
        ./scripts/describe-skills.sh {{ FLAKE_DIR }} "${detail:-desktop}"
        ;;
      *)
        {{ _nix }} eval --json {{ FLAKE_DIR }}#homeConfigurations."$target".config --apply 'config: {
          inherit (config.my) hostName os desktop identities secrets;
          gpuBackend = config.my.gpu.backend;
          appBundles = config.my.apps.bundles;
          appEnabled = config.my.apps.enabled;
          aiBundles = config.my.ai.bundles;
          aiClients = builtins.attrNames config.my.ai.clients;
        }' | jq .
        ;;
    esac

# Run dotfiles diagnostics: `just doctor`, `just doctor secrets`
doctor module="" detail="":
    #!/usr/bin/env bash
    set -euo pipefail
    module="{{ module }}"

    case "$module" in
      "")
        just doctor completions
        just doctor secrets "${detail:-desktop}"
        just doctor skills "${detail:-desktop}"
        ;;
      completions)
        if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
          printf '\033[1m==> completions\033[0m\n'
        else
          echo "==> completions"
        fi
        just describe completions
        ;;
      secrets)
        ./scripts/doctor-secrets.sh {{ FLAKE_DIR }} "${detail:-desktop}"
        ;;
      skills)
        ./scripts/doctor-skills.sh {{ FLAKE_DIR }} "${detail:-desktop}"
        ;;
      *)
        echo "Unknown doctor module: $module" >&2
        echo "Known modules: completions, secrets, skills" >&2
        exit 1
        ;;
    esac

# Run flake.checks (eval-only — catches bundle/enum/assertion errors fast)
check: docs
    {{ _nix }} flake check --no-build {{ FLAKE_DIR }}

# Apply tracked Codex preferences without switching the full Home Manager profile.
codex-config-apply:
    command codex-config-apply

# Apply a host configuration: `just switch desktop`
switch host: docs
    @if [ ! -f "$HOME/.secrets/age_identity" ]; then \
      echo "Error: Missing ~/.secrets/age_identity — restore from Bitwarden"; \
      exit 1; \
    fi
    @echo "==> Applying host {{ host }} using flake at {{ FLAKE_DIR }}"
    nh home switch -b backup -c {{ host }} {{ FLAKE_DIR }}
    @just clean

# Build a host activation package without activating; shows nvd diff vs current
build host:
    nh home build -c {{ host }} {{ FLAKE_DIR }}

# On macOS Tahoe (26+) with MDM (Jamf/Intune/MDE), `nix store gc` fails with
# EPERM on `.app` bundles carrying com.apple.macl / com.apple.provenance xattrs
# — the daemon's chmod is refused, and MDM re-stamps the xattrs during
# compliance scans so stripping them isn't durable. Profile pruning has already
# happened by the time GC runs, so on macOS we tolerate the failure (leading
# `-`) to keep `just switch` from reporting a false negative.
# Wipe nix profile and GC entries older than 14 days; keep min 3 generations
[macos]
clean:
    @echo "==> Cleaning up old generations"
    @-nh clean user --keep-since 14d --keep 3 2>&1 | awk '!skip && /Performing garbage collection on the nix store/{print "==> Skipping nix store gc on Darwin (Tahoe+MDM xattr issue — see justfile comment)"; skip=1; next} !skip'

# Wipe nix profile and GC entries older than 14 days; keep min 3 generations
[linux]
clean:
    @echo "==> Cleaning up old generations"
    nh clean user --keep-since 14d --keep 3

# Deduplicate the nix store (slow, run occasionally)
optimise:
    @echo "==> Optimising and deduplicating nix store"
    {{ _nix }} store optimise
