FLAKE_DIR := "."

# Inputs excluded from `just update` (heavy rebuilds). Bump explicitly.

PINNED := "nixpkgs-pinned"
[private]
_nix := "nix --extra-experimental-features 'nix-command flakes'"

# Update flake inputs (skips PINNED), or a subset: `just update llm-agents nixpkgs`
update *inputs:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{ inputs }}" ]; then
      {{ _nix }} flake update {{ inputs }}
    else
      all=$({{ _nix }} eval --raw --impure --expr \
        'builtins.concatStringsSep "\n" (builtins.attrNames (builtins.getFlake (toString ./.)).inputs)')
      to_update=$(comm -23 <(echo "$all" | sort) <(echo "{{ PINNED }}" | tr ' ' '\n' | sort))
      echo "==> Updating: $(echo $to_update | tr '\n' ' ')"
      {{ _nix }} flake update $to_update
    fi

# Bump pinned inputs to latest (e.g. nixpkgs-pinned tracks unstable HEAD)
update-pinned:
    {{ _nix }} flake update {{ PINNED }}

# Show flake outputs (homeConfigurations, apps, etc.)
show:
    {{ _nix }} flake show {{ FLAKE_DIR }}

# Run flake.checks (eval-only — catches bundle/enum/assertion errors fast)
check:
    {{ _nix }} flake check --no-build {{ FLAKE_DIR }}

# Apply a host configuration: `just switch desktop`
switch host:
    @if [ ! -f "$HOME/.secrets/age_identity" ]; then \
      echo "Error: Missing ~/.secrets/age_identity — restore from Bitwarden"; \
      exit 1; \
    fi
    @echo "==> Applying host {{ host }} using flake at {{ FLAKE_DIR }}"
    nh home switch -b backup -c {{ host }} {{ FLAKE_DIR }}

    just clean

# Build a host activation package without activating; shows nvd diff vs current
build host:
    nh home build -c {{ host }} {{ FLAKE_DIR }}

# Wipe nix profile and GC entries older than 14 days; keep min 3 generations
clean:
    @echo "==> Cleaning up old generations"
    nh clean user --keep-since 14d --keep 3

# Deduplicate the nix store (slow, run occasionally)
optimise:
    @echo "==> Optimising and deduplicating nix store"
    {{ _nix }} store optimise
