logging {
  level  = "info"
  format = "logfmt"
}

otelcol.receiver.otlp "agents" {
  grpc {
    endpoint = "0.0.0.0:4327"
  }

  output {
    traces = [otelcol.processor.filter.evaluations.input]
  }
}

otelcol.processor.filter "evaluations" {
  error_mode = "ignore"

  trace_conditions {
    context = "resource"
    conditions = [
      `resource.attributes["telemetry.purpose"] != "evaluation"`,
    ]
  }

  output {
    traces = [otelcol.processor.transform.redact_identity.input]
  }
}

otelcol.processor.transform "redact_identity" {
  error_mode = "ignore"

  trace_statements {
    context = "resource"
    statements = [
      `delete_key(resource.attributes, "organization.id")`,
      `delete_key(resource.attributes, "user.account_id")`,
      `delete_key(resource.attributes, "user.account_uuid")`,
      `delete_key(resource.attributes, "user.email")`,
      `delete_key(resource.attributes, "user.id")`,
    ]
  }

  trace_statements {
    context = "span"
    statements = [
      `delete_key(span.attributes, "authorization")`,
      `delete_key(span.attributes, "http.request.header.authorization")`,
      `delete_key(span.attributes, "organization.id")`,
      `delete_key(span.attributes, "user.account_id")`,
      `delete_key(span.attributes, "user.account_uuid")`,
      `delete_key(span.attributes, "user.email")`,
      `delete_key(span.attributes, "user.id")`,
    ]
  }

  output {
    traces = [otelcol.processor.batch.evaluations.input]
  }
}

otelcol.processor.batch "evaluations" {
  timeout = "1s"

  output {
    traces = [otelcol.exporter.otlphttp.mlflow.input]
  }
}

otelcol.exporter.otlphttp "mlflow" {
  client {
    endpoint    = "http://mlflow:5000"
    compression = "gzip"
    headers = {
      "x-mlflow-experiment-id" = sys.env("MLFLOW_EXPERIMENT_ID"),
    }
  }
}
